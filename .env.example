# FinBot Environment Variables

# Groq LLM API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model
GROQ_MODEL=openai/gpt-oss-20b

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=finbot_docs

# Embedding Model (used for both document storage and semantic router)
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# SQLite Database
DATABASE_URL=sqlite:///./finbot.db

# Data Directory (relative to backend/)
DATA_DIR=../data

# Session Rate Limit
RATE_LIMIT_PER_SESSION=20
