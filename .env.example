# FinBot Environment Variables

# Groq LLM API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (options: llama-3.1-8b-instant, llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.1-8b-instant

# Qdrant Vector Database
# Use 'local' for embedded mode (no Docker needed) or 'http://localhost:6333' for Docker
QDRANT_URL=local
QDRANT_COLLECTION=finbot_docs

# Embedding Model (Fast, CPU-friendly for local performance)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# SQLite Database
DATABASE_URL=sqlite:///./finbot.db

# Data Directory (relative to project root)
DATA_DIR=./data

# Session Rate Limit
RATE_LIMIT_PER_SESSION=20

# Offline mode (Enable once models are cached to prevent SSL/Network issues)
TRANSFORMERS_OFFLINE=0
HF_HUB_OFFLINE=0
